# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your ngrok https URL — https://dashboard.ngrok.com/early-access
WEBHOOK_URL=

# A random secret you choose — allowed chars: A-Z a-z 0-9 _ - (1-256 chars).
# Generate one with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

PORT=3000

# From console.anthropic.com
ANTHROPIC_API_KEY=

# From Supabase dashboard → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# From trigger.dev → Project → API keys
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=

# From dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
# From `stripe listen` output or Stripe dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=

# WhatsApp Cloud API — from developers.facebook.com → Your App → WhatsApp
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
# developers.facebook.com → Your App → Settings → Basic → App Secret
WHATSAPP_APP_SECRET=
